#!/usr/bin/env bash
# ./sandbox — enter the disposable Module 1 Linux container.
#
# Requires Docker. If Docker isn't installed (or isn't running), this prints
# guidance for your operating system and exits without touching anything.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGE="module3-git-sandbox"

# --- OS-specific Docker install guidance ------------------------------------

detect_os() {
  case "$(uname -s)" in
    Darwin) echo "mac" ;;
    Linux)
      if grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null; then
        echo "wsl"
      else
        echo "linux"
      fi
      ;;
    *) echo "other" ;;
  esac
}

print_install_help() {
  echo
  echo "==============================================================="
  echo " This lesson needs Docker, and it isn't installed."
  echo "==============================================================="
  echo
  echo " Docker gives you a THROWAWAY Linux machine — the only way to"
  echo " practice destructive commands (rm, chmod) with zero risk to your"
  echo " real files. Please install it, then re-run:  ./sandbox"
  echo
  case "$(detect_os)" in
    mac)
      cat <<'EOF'
 macOS
 -----
 1. Install Docker Desktop:
      - Download: https://www.docker.com/products/docker-desktop/
      - or with Homebrew:   brew install --cask docker
 2. Open the Docker app once so the engine starts (whale icon in the menu bar).
 3. Re-run:  ./sandbox
EOF
      ;;
    linux)
      cat <<'EOF'
 Linux
 -----
 1. Install Docker Engine (pick one):
      - Your package manager, e.g.:  sudo apt-get install docker.io
      - or the official script:       curl -fsSL https://get.docker.com | sh
      - Full docs: https://docs.docker.com/engine/install/
 2. Run without sudo (recommended):
      sudo usermod -aG docker "$USER"
      # then log out and back in for the group to take effect
 3. Start it:  sudo systemctl start docker
 4. Re-run:  ./sandbox
EOF
      ;;
    wsl)
      cat <<'EOF'
 Windows (via WSL2 — you're in the right shell)
 ----------------------------------------------
 1. Install Docker Desktop for Windows with the WSL2 backend:
      https://www.docker.com/products/docker-desktop/
 2. In Docker Desktop: Settings -> Resources -> WSL Integration,
    enable it for this distro.
 3. Keep running ./sandbox from THIS WSL shell (not cmd/PowerShell).
 4. Re-run:  ./sandbox
EOF
      ;;
    *)
      cat <<'EOF'
 Install Docker for your platform:
   https://docs.docker.com/get-docker/
 Then re-run:  ./sandbox

 On Windows, install Docker Desktop (WSL2 backend) and run ./sandbox
 from inside a WSL2 shell or Git Bash — not cmd/PowerShell.
EOF
      ;;
  esac
  echo
}

# --- Docker gate ------------------------------------------------------------

if ! command -v docker >/dev/null 2>&1; then
  print_install_help
  exit 1
fi

if ! docker info >/dev/null 2>&1; then
  echo
  echo "Docker is installed but its engine isn't running."
  case "$(detect_os)" in
    mac|wsl) echo "  Start Docker Desktop (whale icon), wait for it to say 'running', then re-run: ./sandbox" ;;
    linux)   echo "  Start it with:  sudo systemctl start docker    then re-run: ./sandbox" ;;
    *)       echo "  Start the Docker engine, then re-run: ./sandbox" ;;
  esac
  echo
  exit 1
fi

# --- Build (cached after first run) and enter -------------------------------

echo "Preparing the sandbox image (first run downloads Debian; later runs are instant)..."
docker build -t "$IMAGE" -f "$DIR/docker/Dockerfile" "$DIR"

echo "Entering the throwaway sandbox. Type 'exit' to leave; it self-destructs on exit."
exec docker run --rm -it "$IMAGE"
