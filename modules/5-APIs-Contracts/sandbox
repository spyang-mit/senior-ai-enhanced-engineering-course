#!/usr/bin/env bash
# ./sandbox — enter the disposable Module 5 container.
#
# Unlike earlier modules, your CODE lives in the mounted workspace/ folder:
# the container is throwaway but your work persists on the host.
#
# Requires Docker. If Docker isn't installed, prints platform-specific guidance.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGE="module5-api-sandbox"

# --- OS-specific Docker install guidance ------------------------------------
detect_os() {
  case "$(uname -s)" in
    Darwin) echo "mac" ;;
    Linux)
      if grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null; then
        echo "wsl"
      else
        echo "linux"
      fi
      ;;
    *) echo "other" ;;
  esac
}

print_install_help() {
  echo
  echo "==============================================================="
  echo " This lesson needs Docker, and it isn't installed."
  echo "==============================================================="
  echo
  echo " Docker gives you a THROWAWAY Linux machine. Please install it,"
  echo " then re-run:  ./sandbox"
  echo
  case "$(detect_os)" in
    mac)
      cat <<'EOF'
 macOS
 -----
 1. Install Docker Desktop:
      - Download: https://www.docker.com/products/docker-desktop/
      - or with Homebrew:   brew install --cask docker
 2. Open the Docker app once so the engine starts (whale icon in the menu bar).
 3. Re-run:  ./sandbox
EOF
      ;;
    linux)
      cat <<'EOF'
 Linux
 -----
 1. Install Docker Engine:
      sudo apt-get install docker.io    (or your package manager)
      or:  curl -fsSL https://get.docker.com | sh
 2. Run without sudo (recommended):  sudo usermod -aG docker "$USER"
    Then log out and back in.
 3. Start it:  sudo systemctl start docker
 4. Re-run:  ./sandbox
EOF
      ;;
    wsl)
      cat <<'EOF'
 Windows (via WSL2)
 ------------------
 1. Install Docker Desktop for Windows with the WSL2 backend.
 2. Enable WSL integration in Docker Desktop settings.
 3. Keep running ./sandbox from THIS WSL shell (not cmd/PowerShell).
EOF
      ;;
    *)
      cat <<'EOF'
 Install Docker for your platform:  https://docs.docker.com/get-docker/
 Then re-run:  ./sandbox
EOF
      ;;
  esac
  echo
}

# --- Docker gate ------------------------------------------------------------
if ! command -v docker >/dev/null 2>&1; then
  print_install_help
  exit 1
fi

if ! docker info >/dev/null 2>&1; then
  echo
  echo "Docker is installed but its engine isn't running."
  case "$(detect_os)" in
    mac|wsl) echo "  Start Docker Desktop (whale icon), wait for 'running', then re-run: ./sandbox" ;;
    linux)   echo "  Start it with:  sudo systemctl start docker    then re-run: ./sandbox" ;;
    *)       echo "  Start the Docker engine, then re-run: ./sandbox" ;;
  esac
  echo
  exit 1
fi

# --- Ensure the workspace directory exists on the host -----------------------
mkdir -p "$DIR/workspace/handlers"

# --- Build and enter --------------------------------------------------------
echo "Preparing the sandbox image (first run downloads Debian; later runs are instant)..."
docker build -t "$IMAGE" -f "$DIR/docker/Dockerfile" "$DIR"

echo ""
echo "┌─────────────────────────────────────────────────────────────────────┐"
echo "│ Module 5 — APIs, contracts & the client/server boundary            │"
echo "│                                                                     │"
echo "│ The orders API is on http://localhost:8080                          │"
echo "│ Your CODE lives in:  workspace/  (on your host machine)             │"
echo "│                                                                     │"
echo "│ Two-terminal workflow:                                              │"
echo "│  1. In THIS container:  lesson next                                 │"
echo "│  2. In a HOST terminal: edit workspace/handlers/ via AI / editor    │"
echo "│  3. Back in container:  lesson check  (restarts server, verifies)   │"
echo "└─────────────────────────────────────────────────────────────────────┘"
echo ""
echo "Type 'exit' to leave (container self-destructs; your workspace/ stays)."

exec docker run --rm -it -p 8080:8080 \
  -v "$DIR/workspace:/home/dev/workspace" \
  "$IMAGE"
